<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Risk Analyzer — Ice Cold Analytics</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --deep: #1C2026;
    --surface: #242A32;
    --surface-2: #2C3440;
    --surface-3: #323A48;
    --border: rgba(200,230,245,0.12);
    --border-bright: rgba(200,230,245,0.25);
    --text-primary: #F0F7FC;
    --text-secondary: #90BDD4;
    --text-muted: #5A7A90;
    --accent: #00C2FF;
    --accent-dim: rgba(0,194,255,0.12);
    --red: #FF4444;
    --amber: #FFB020;
    --green: #22C55E;
    --red-dim: rgba(255,68,68,0.1);
    --amber-dim: rgba(255,176,32,0.1);
    --green-dim: rgba(34,197,94,0.1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    background: var(--deep);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 70% 40% at 50% 0%, rgba(0,194,255,0.05) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 64px;
    background: rgba(28,32,38,0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo { text-decoration: none; }
  .nav-logo-top {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 5px;
    color: var(--text-primary);
  }
  .nav-logo-top span { color: var(--accent); }
  .nav-logo-bottom {
    font-family: 'DM Mono', monospace;
    font-size: 7px;
    letter-spacing: 3px;
    color: var(--text-muted);
    text-transform: uppercase;
    display: block;
    margin-top: 1px;
  }

  .nav-back {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.2s;
  }
  .nav-back:hover { color: var(--text-primary); }

  /* ── MAIN LAYOUT ── */
  .page {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 100px 40px 80px;
  }

  .page-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 8vw, 80px);
    letter-spacing: 2px;
    line-height: 1;
    margin-bottom: 12px;
  }

  .page-desc {
    font-size: 15px;
    font-weight: 300;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.8;
    margin-bottom: 48px;
  }

  /* ── ANALYZER LAYOUT ── */
  .analyzer-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 24px;
    align-items: start;
  }

  /* ── PANELS ── */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .panel-header {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--surface-2);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .panel-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .panel-body { padding: 24px; }

  /* ── GAME SELECTOR ── */
  .game-selector {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 16px;
    align-items: center;
    margin-bottom: 28px;
  }

  .team-input-group { display: flex; flex-direction: column; gap: 8px; }

  .input-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .team-input {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 2px;
    background: var(--surface-3);
    border: 1px solid var(--border-bright);
    color: var(--text-primary);
    padding: 12px 16px;
    border-radius: 4px;
    outline: none;
    width: 100%;
    text-transform: uppercase;
    transition: border-color 0.2s;
  }

  .team-input:focus { border-color: var(--accent); }
  .team-input::placeholder { color: var(--text-muted); font-size: 24px; }

  .vs-divider {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--text-muted);
    text-align: center;
    padding-top: 24px;
  }

  /* ── FACTORS ── */
  .factors-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .factors-group {
    margin-bottom: 24px;
  }

  .factors-group-label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .factor-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-radius: 5px;
    margin-bottom: 8px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.15s;
    background: var(--surface-3);
    user-select: none;
  }

  .factor-row:hover { border-color: var(--border-bright); }

  .factor-row.active-red   { background: var(--red-dim);   border-color: rgba(255,68,68,0.3); }
  .factor-row.active-amber { background: var(--amber-dim); border-color: rgba(255,176,32,0.3); }
  .factor-row.active-green { background: var(--green-dim); border-color: rgba(34,197,94,0.3); }

  .factor-left { display: flex; align-items: center; gap: 10px; }

  .factor-icon { font-size: 16px; width: 24px; text-align: center; }

  .factor-text { }
  .factor-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.3;
  }
  .factor-sub {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    color: var(--text-muted);
    margin-top: 2px;
    letter-spacing: 0.5px;
  }

  .factor-weight {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 3px;
    min-width: 50px;
    text-align: center;
  }

  .weight-red   { color: var(--red);   background: var(--red-dim); }
  .weight-amber { color: var(--amber); background: var(--amber-dim); }
  .weight-green { color: var(--green); background: var(--green-dim); }
  .weight-neutral { color: var(--text-muted); background: rgba(90,122,144,0.15); }

  /* Toggle switch */
  .toggle {
    width: 36px; height: 20px;
    background: var(--surface-2);
    border: 1px solid var(--border-bright);
    border-radius: 10px;
    position: relative;
    transition: all 0.2s;
    flex-shrink: 0;
    cursor: pointer;
  }

  .toggle::after {
    content: '';
    position: absolute;
    width: 14px; height: 14px;
    background: var(--text-muted);
    border-radius: 50%;
    top: 2px; left: 2px;
    transition: all 0.2s;
  }

  .factor-row.active-red   .toggle,
  .factor-row.active-amber .toggle,
  .factor-row.active-green .toggle { background: var(--accent); border-color: var(--accent); }

  .factor-row.active-red   .toggle::after,
  .factor-row.active-amber .toggle::after,
  .factor-row.active-green .toggle::after {
    left: 18px;
    background: white;
  }

  /* ── RESULTS PANEL ── */
  .result-panel {
    position: sticky;
    top: 84px;
  }

  /* Risk Meter */
  .risk-meter-wrap {
    padding: 28px 24px 20px;
    text-align: center;
    border-bottom: 1px solid var(--border);
  }

  .risk-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .risk-gauge {
    position: relative;
    width: 200px;
    height: 110px;
    margin: 0 auto 16px;
  }

  .gauge-svg { width: 100%; height: 100%; overflow: visible; }

  .gauge-track {
    fill: none;
    stroke: var(--surface-3);
    stroke-width: 14;
    stroke-linecap: round;
  }

  .gauge-fill {
    fill: none;
    stroke-width: 14;
    stroke-linecap: round;
    transition: stroke-dashoffset 0.6s cubic-bezier(0.4,0,0.2,1), stroke 0.4s;
    transform-origin: center;
  }

  .gauge-needle {
    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);
    transform-origin: 100px 100px;
  }

  .risk-score-display {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 56px;
    letter-spacing: 2px;
    line-height: 1;
    transition: color 0.4s;
  }

  .risk-score-label {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-top: 4px;
    transition: color 0.4s;
  }

  /* Result stats */
  .result-stats {
    padding: 20px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    border-bottom: 1px solid var(--border);
  }

  .stat-box {
    background: var(--surface-3);
    border-radius: 5px;
    padding: 12px 14px;
    text-align: center;
  }

  .stat-box-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 1px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 4px;
    transition: color 0.3s;
  }

  .stat-box-label {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Verdict */
  .verdict-box {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
  }

  .verdict-header {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .verdict-text {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.7;
    min-height: 60px;
    transition: color 0.3s;
  }

  /* Active factors summary */
  .active-factors {
    padding: 16px 24px;
  }

  .active-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  .active-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    min-height: 30px;
  }

  .active-tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    padding: 4px 10px;
    border-radius: 3px;
    animation: tagPop 0.2s ease;
  }

  .tag-red   { background: var(--red-dim);   color: var(--red);   border: 1px solid rgba(255,68,68,0.25); }
  .tag-amber { background: var(--amber-dim); color: var(--amber); border: 1px solid rgba(255,176,32,0.2); }
  .tag-green { background: var(--green-dim); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }

  .no-factors {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    font-style: italic;
  }

  /* CTA */
  .result-cta {
    padding: 20px 24px;
    background: var(--surface-2);
  }

  .btn-primary {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: var(--accent);
    color: var(--deep);
    border: none;
    padding: 13px 24px;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: block;
    text-align: center;
    font-weight: 500;
  }

  .btn-primary:hover {
    background: #33CFFF;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0,194,255,0.25);
  }

  .btn-secondary {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-bright);
    padding: 13px 24px;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: block;
    text-align: center;
    margin-top: 8px;
  }

  .btn-secondary:hover { color: var(--text-primary); border-color: rgba(200,230,245,0.4); }

  /* Disclaimer */
  .disclaimer-strip {
    position: relative;
    z-index: 1;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    color: var(--text-muted);
    text-align: center;
    padding: 20px 40px 32px;
    line-height: 1.9;
    border-top: 1px solid var(--border);
    opacity: 0.6;
    margin-top: 40px;
  }

  @keyframes tagPop {
    from { transform: scale(0.8); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .page-label, .page-title, .page-desc, .analyzer-grid {
    animation: fadeUp 0.5s ease both;
  }
  .page-title  { animation-delay: 0.05s; }
  .page-desc   { animation-delay: 0.1s; }
  .analyzer-grid { animation-delay: 0.15s; }

  @media (max-width: 900px) {
    nav { padding: 0 20px; }
    .page { padding: 90px 20px 60px; }
    .analyzer-grid { grid-template-columns: 1fr; }
    .result-panel { position: static; }
  }

  /* ── MONEYLINE COMPARISON ── */
  .ml-section {
    margin-top: 24px;
  }

  .ml-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-bottom: 16px;
  }

  .ml-book {
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 12px 14px;
    transition: border-color 0.2s;
  }

  .ml-book.best-value {
    border-color: rgba(0,194,255,0.4);
    background: rgba(0,194,255,0.05);
  }

  .ml-book-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .ml-book-name {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .best-badge {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 2px 7px;
    border-radius: 2px;
    display: none;
  }

  .ml-book.best-value .best-badge { display: block; }

  .ml-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .ml-input-wrap { display: flex; flex-direction: column; gap: 3px; }

  .ml-side-label {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .ml-input {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text-primary);
    padding: 7px 10px;
    border-radius: 3px;
    outline: none;
    width: 100%;
    text-align: center;
    transition: border-color 0.2s;
  }

  .ml-input:focus { border-color: var(--accent); }
  .ml-input::placeholder { color: var(--text-muted); font-size: 12px; }

  .ml-imp {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 4px;
    height: 14px;
    transition: color 0.2s;
  }

  /* Odds comparison bar */
  .odds-comparison {
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 14px 16px;
    margin-top: 8px;
  }

  .odds-comp-title {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .odds-comp-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .odds-comp-book {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 1px;
    color: var(--text-muted);
    width: 80px;
    flex-shrink: 0;
  }

  .odds-comp-bar-wrap {
    flex: 1;
    height: 6px;
    background: var(--surface-2);
    border-radius: 3px;
    overflow: hidden;
  }

  .odds-comp-bar {
    height: 100%;
    border-radius: 3px;
    transition: width 0.4s ease;
    background: var(--accent);
  }

  .odds-comp-val {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--text-secondary);
    width: 50px;
    text-align: right;
    flex-shrink: 0;
  }

  .odds-comp-val.best { color: var(--accent); font-weight: 500; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="index.html" class="nav-logo">
    <span class="nav-logo-top">ICE <span>COLD</span></span>
    <span class="nav-logo-bottom">Analytics</span>
  </a>
  <a href="index.html" class="nav-back">← Back to Dashboard</a>
</nav>

<!-- PAGE -->
<div class="page">
  <div class="page-label">Tool</div>
  <div class="page-title">Risk Analyzer</div>
  <p class="page-desc">Select a matchup, toggle the situational factors that apply, and see how the Ice Cold model reads the risk. Built on 17 years of NHL data.</p>

  <div class="analyzer-grid">

    <!-- LEFT: INPUT PANEL -->
    <div>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">Game Setup</div>
          <div style="font-family:'DM Mono',monospace;font-size:9px;color:var(--text-muted);letter-spacing:1px;">Enter team abbreviations</div>
        </div>
        <div class="panel-body">

          <!-- Team selector -->
          <div class="game-selector">
            <div class="team-input-group">
              <div class="input-label">Away Team</div>
              <input class="team-input" id="awayTeam" type="text" maxlength="3" placeholder="TOR" oninput="this.value=this.value.toUpperCase();updateAnalysis()">
            </div>
            <div class="vs-divider">@</div>
            <div class="team-input-group">
              <div class="input-label">Home Team</div>
              <input class="team-input" id="homeTeam" type="text" maxlength="3" placeholder="FLA" oninput="this.value=this.value.toUpperCase();updateAnalysis()">
            </div>
          </div>

          <!-- FACTORS -->
          <div class="factors-title">Situational Factors</div>

          <!-- AWAY FATIGUE -->
          <div class="factors-group">
            <div class="factors-group-label">Away Team Fatigue</div>

            <div class="factor-row" id="f-away-b2b" onclick="toggleFactor('f-away-b2b')">
              <div class="factor-left">
                <div class="factor-icon">📅</div>
                <div class="factor-text">
                  <div class="factor-name" style="font-size:15px;font-weight:500">Away Back-to-Back</div>
                  <div class="factor-sub">Away team played yesterday</div>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:10px;">
                <span class="factor-weight weight-red" data-weight="-8" data-color="red">−8%</span>
                <div class="toggle"></div>
              </div>
            </div>

            <div class="factor-row" id="f-away-backup" onclick="toggleFactor('f-away-backup')">
              <div class="factor-left">
                <div class="factor-icon">🥅</div>
                <div class="factor-text">
                  <div class="factor-name">Away Backup Goalie</div>
                  <div class="factor-sub">Backup expected to start</div>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:10px;">
                <span class="factor-weight weight-red" data-weight="-6" data-color="red">−6%</span>
                <div class="toggle"></div>
              </div>
            </div>

            <div class="factor-row" id="f-away-b2b-backup" onclick="toggleFactor('f-away-b2b-backup')">
              <div class="factor-left">
                <div class="factor-icon">⚡</div>
                <div class="factor-text">
