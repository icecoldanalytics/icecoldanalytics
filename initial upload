<script>
var FACTORS = {
  'f-away-b2b':         { name: 'Away B2B',          weight: -8,  color: 'red',   tag: 'AWAY B2B' },
  'f-away-backup':      { name: 'Away Backup Goalie', weight: -12, color: 'red',   tag: 'BACKUP GOALIE' },
  'f-away-b2b-backup':  { name: 'B2B + Backup',       weight: -14, color: 'red',   tag: 'B2B + BACKUP' },
  'f-away-travel':      { name: 'Long Haul Travel',   weight: -2,  color: 'amber', tag: '1500MI+ TRAVEL' },
  'f-home-rest':        { name: 'Home Rested 3+ days',weight: -4,  color: 'green', tag: 'HOME RESTED' },
  'f-home-goalie':      { name: 'Home Goalie Edge',   weight: 4,   color: 'green', tag: 'GOALIE EDGE' },
  'f-home-b2b':         { name: 'Home B2B',           weight: 6,   color: 'amber', tag: 'HOME B2B' },
  'f-home-form':        { name: 'Home Strong Form',   weight: 3,   color: 'green', tag: 'HOT STREAK' },
  'f-away-form':        { name: 'Away Poor Form',     weight: -3,  color: 'amber', tag: 'AWAY COLD' }
};

var activeFactors = {};

function toggleFactor(id) {
  var el = document.getElementById(id);
  if (!el) { console.error('No element:', id); return; }
  var f = FACTORS[id];
  if (!f) { console.error('No factor:', id); return; }

  if (activeFactors[id]) {
    delete activeFactors[id];
    el.className = 'factor-row';
  } else {
    activeFactors[id] = true;
    el.className = 'factor-row active-' + f.color;
  }
  updateAnalysis();
}

function updateAnalysis() {
  var away = document.getElementById('awayTeam').value || 'AWAY';
  var home = document.getElementById('homeTeam').value || 'HOME';
  var ids = Object.keys(activeFactors);
  var count = ids.length;

  var totalEdge = 0;
  ids.forEach(function(id) { totalEdge += FACTORS[id].weight; });

  // Active tags
  var tagsEl = document.getElementById('activeTags');
  if (count === 0) {
    tagsEl.innerHTML = '<span class="no-factors">No factors selected</span>';
  } else {
    tagsEl.innerHTML = ids.map(function(id) {
      var f = FACTORS[id];
      return '<span class="active-tag tag-' + f.color + '">' + f.tag + '</span>';
    }).join('');
  }

  document.getElementById('statFactors').textContent = count;

  if (count === 0) { resetDisplay(); return; }

  var edgeStr = totalEdge >= 0 ? '+' + totalEdge + '%' : totalEdge + '%';
  var edgeEl = document.getElementById('statEdge');
  edgeEl.textContent = edgeStr;
  edgeEl.style.color = totalEdge > 0 ? 'var(--green)' : totalEdge < -8 ? 'var(--red)' : 'var(--amber)';

  var absEdge = Math.abs(totalEdge);
  var level, confidence;
  if (absEdge >= 14)      { level = '3 / 3'; confidence = 'HIGH'; }
  else if (absEdge >= 8)  { level = '2 / 3'; confidence = 'MED'; }
  else if (absEdge >= 4)  { level = '1 / 3'; confidence = 'LOW'; }
  else                    { level = '—';     confidence = '—'; }

  document.getElementById('statSignal').textContent = level;
  var confEl = document.getElementById('statConfidence');
  confEl.textContent = confidence;
  confEl.style.color = confidence === 'HIGH' ? 'var(--green)' : confidence === 'MED' ? 'var(--amber)' : 'var(--text-muted)';

  updateGauge(totalEdge);

  var scoreEl = document.getElementById('riskScore');
  var labelEl = document.getElementById('riskLabel');
  scoreEl.textContent = edgeStr;

  if (totalEdge <= -10) {
    scoreEl.style.color = 'var(--red)';
    labelEl.style.color = 'var(--red)';
    labelEl.textContent = 'FADE ' + away;
  } else if (totalEdge <= -4) {
    scoreEl.style.color = 'var(--amber)';
    labelEl.style.color = 'var(--amber)';
    labelEl.textContent = 'LEAN ' + home;
  } else if (totalEdge >= 8) {
    scoreEl.style.color = 'var(--green)';
    labelEl.style.color = 'var(--green)';
    labelEl.textContent = 'BACK ' + home;
  } else if (totalEdge > 0) {
    scoreEl.style.color = 'var(--green)';
    labelEl.style.color = 'var(--text-secondary)';
    labelEl.textContent = 'SLIGHT LEAN';
  } else {
    scoreEl.style.color = 'var(--text-muted)';
    labelEl.style.color = 'var(--text-muted)';
    labelEl.textContent = 'NEUTRAL';
  }

  updateVerdict(away, home, totalEdge, absEdge);
}

function updateGauge(edge) {
  var clipped = Math.max(-20, Math.min(20, edge));
  var pct = (clipped + 20) / 40;
  var arcLen = 251;
  var offset = arcLen - (pct * arcLen);
  var fill = document.getElementById('gaugeFill');
  fill.style.strokeDashoffset = offset;
  fill.style.stroke = edge <= -10 ? 'var(--red)' : edge <= -4 ? 'var(--amber)' : edge >= 8 ? 'var(--green)' : 'var(--accent)';
  var angle = pct * 180 - 90;
  document.getElementById('gaugeNeedle').style.transform = 'rotate(' + angle + 'deg)';
}

function updateVerdict(away, home, edge, abs) {
  var el = document.getElementById('verdictText');
  var awayLabel = away !== 'AWAY' ? away : 'the away team';
  var homeLabel = home !== 'HOME' ? home : 'the home team';

  if (abs < 4) {
    el.textContent = 'No strong edge detected. The active factors roughly cancel out — this game sits close to a coin flip based on situational data alone.';
    el.style.color = 'var(--text-secondary)';
  } else if (edge <= -14) {
    el.textContent = 'Maximum alert — ' + awayLabel + ' is in a high-fatigue situation. Signal 2 (B2B + backup goalie) is active. Backtested at +38.7% ROI. Back ' + homeLabel + '.';
    el.style.color = 'var(--red)';
  } else if (edge <= -10) {
    el.textContent = 'Strong situational edge for ' + homeLabel + '. Multiple fatigue factors stacking against ' + awayLabel + '. Signal 1 + additional context active. Worth a look at the line.';
    el.style.color = 'var(--red)';
  } else if (edge <= -6) {
    el.textContent = 'Moderate lean toward ' + homeLabel + '. ' + awayLabel + ' carries meaningful fatigue disadvantage tonight. Check the line.';
    el.style.color = 'var(--amber)';
  } else if (edge <= -4) {
    el.textContent = 'Slight lean toward ' + homeLabel + '. Worth monitoring closer to puck drop — goalie confirmation could strengthen this.';
    el.style.color = 'var(--text-secondary)';
  } else if (edge >= 8) {
    el.textContent = 'Strong situational profile for ' + homeLabel + '. Rested home team with clear edge. High confidence read.';
    el.style.color = 'var(--green)';
  } else {
    el.textContent = 'Slight situational lean toward ' + homeLabel + '. Positive setup but not a high-conviction signal on its own.';
    el.style.color = 'var(--text-secondary)';
  }
}

// Moneyline logic
var BOOKS = ['pinnacle', 'draftkings', 'fanduel', 'betmgm'];

function americanToProb(odds) {
  var o = parseFloat(odds);
  if (isNaN(o)) return null;
  return o < 0 ? (-o) / ((-o) + 100) : 100 / (o + 100);
}

function updateOdds() {
  var away = document.getElementById('awayTeam').value || 'Away';
  var home = document.getElementById('homeTeam').value || 'Home';

  BOOKS.forEach(function(book) {
    ['away','home'].forEach(function(side) {
      var input = document.getElementById('ml-' + book + '-' + side);
      var impEl = document.getElementById('imp-' + book + '-' + side);
      if (!input || !impEl) return;
      var prob = americanToProb(input.value.trim());
      impEl.textContent = prob !== null ? (prob * 100).toFixed(1) + '% imp.' : '';
      impEl.style.color = 'var(--text-secondary)';
    });
  });

  var bestHomeProb = Infinity, bestBook = null, bookProbs = {};
  BOOKS.forEach(function(book) {
    var input = document.getElementById('ml-' + book + '-home');
    if (!input || !input.value.trim()) return;
    var prob = americanToProb(input.value.trim());
    if (prob !== null) {
      bookProbs[book] = prob;
      if (prob < bestHomeProb) { bestHomeProb = prob; bestBook = book; }
    }
  });

  BOOKS.forEach(function(book) {
    var el = document.getElementById('book-' + book);
    if (el) el.classList.toggle('best-value', book === bestBook);
  });

  var compEl = document.getElementById('oddsComparison');
  var barsEl = document.getElementById('oddsCompBars');
  var compTitle = document.getElementById('oddsCompTitle');
  var keys = Object.keys(bookProbs);

  if (keys.length >= 2) {
    compEl.style.display = 'block';
    compTitle.textContent = home + ' Win — Implied Probability by Book';
    var probs = keys.map(function(k) { return bookProbs[k]; });
    var minP = Math.min.apply(null, probs), maxP = Math.max.apply(null, probs);
    var range = maxP - minP || 0.01;
    var bookNames = { pinnacle:'Pinnacle', draftkings:'DraftKings', fanduel:'FanDuel', betmgm:'BetMGM' };
    var sorted = keys.sort(function(a,b) { return bookProbs[a]-bookProbs[b]; });
    barsEl.innerHTML = sorted.map(function(book) {
      var prob = bookProbs[book];
      var pct = 40 + ((prob - minP) / range) * 55;
      var isBest = book === bestBook;
      return '<div class="odds-comp-row">' +
        '<div class="odds-comp-book">' + bookNames[book] + '</div>' +
        '<div class="odds-comp-bar-wrap"><div class="odds-comp-bar" style="width:' + pct + '%;background:' + (isBest?'var(--accent)':'var(--surface-2)') + ';border:1px solid ' + (isBest?'var(--accent)':'var(--border-bright)') + '"></div></div>' +
        '<div class="odds-comp-val ' + (isBest?'best':'') + '">' + (prob*100).toFixed(1) + '%</div>' +
        '</div>';
    }).join('');
  } else {
    if (compEl) compEl.style.display = 'none';
  }

  updateAnalysis();
}

function resetDisplay() {
  document.getElementById('riskScore').textContent = '—';
  document.getElementById('riskScore').style.color = 'var(--text-muted)';
  document.getElementById('riskLabel').textContent = 'Select factors above';
  document.getElementById('riskLabel').style.color = 'var(--text-muted)';
  document.getElementById('statEdge').textContent = '—';
  document.getElementById('statEdge').style.color = 'var(--text-muted)';
  document.getElementById('statSignal').textContent = '—';
  document.getElementById('statConfidence').textContent = '—';
  document.getElementById('statConfidence').style.color = 'var(--text-muted)';
  document.getElementById('verdictText').textContent = 'Toggle the situational factors that apply to tonight\'s matchup to see the Ice Cold Analytics model assessment.';
  document.getElementById('verdictText').style.color = 'var(--text-secondary)';
  document.getElementById('gaugeFill').style.strokeDashoffset = '251';
  document.getElementById('gaugeNeedle').style.transform = 'rotate(-90deg)';
}
</script>

