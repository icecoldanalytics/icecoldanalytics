    --surface-2: #2C3440;
    --surface-3: #323A48;
    --border: rgba(200,230,245,0.12);
    --border-bright: rgba(200,230,245,0.25);
    --alert-red: #FF4444;
    --alert-amber: #FFB020;
    --alert-green: #22C55E;
    --text-primary: #F0F7FC;
    --text-secondary: #90BDD4;
    --text-muted: #5A7A90;
    --accent: #00C2FF;
    --accent-dim: rgba(0,194,255,0.12);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--deep);
    color: var(--text-primary);
    overflow-x: hidden;
    line-height: 1.6;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(0,194,255,0.05) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 90% 20%, rgba(0,100,180,0.05) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 68px;
    background: rgba(28,32,38,0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-decoration: none;
  }

  .nav-logo-top {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 5px;
    color: var(--text-primary);
  }

  .nav-logo-top span { color: var(--accent); }

  .nav-logo-bottom {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text-primary); }

  .nav-cta {
    color: var(--accent) !important;
    border: 1px solid rgba(0,194,255,0.3);
    padding: 8px 20px;
    border-radius: 3px;
    transition: all 0.2s !important;
  }

  .nav-cta:hover {
    background: var(--accent-dim) !important;
    border-color: var(--accent) !important;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 140px 40px 100px;
    z-index: 1;
  }

  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(0,194,255,0.25);
    padding: 6px 18px;
    border-radius: 2px;
    margin-bottom: 40px;
    display: inline-block;
    animation: fadeUp 0.6s ease both;
  }

  .hero-wordmark {
    animation: fadeUp 0.6s 0.1s ease both;
    margin-bottom: 8px;
  }

  .hero-wordmark-top {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 14vw, 160px);
    letter-spacing: 12px;
    line-height: 0.85;
    color: var(--text-primary);
    display: block;
  }

  .hero-wordmark-top .cold { color: var(--accent); }

  .hero-wordmark-bottom {
    font-family: 'DM Mono', monospace;
    font-size: clamp(12px, 2vw, 18px);
    letter-spacing: 10px;
    text-transform: uppercase;
    color: var(--text-secondary);
    display: block;
    margin-top: 8px;
  }

  .hero-tagline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(18px, 3vw, 28px);
    letter-spacing: 5px;
    color: var(--text-muted);
    margin: 32px 0;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  .hero p {
    max-width: 500px;
    font-size: 16px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 48px;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    animation: fadeUp 0.6s 0.4s ease both;
  }

  /* ── BUTTONS ── */
  .btn-primary {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: var(--accent);
    color: var(--deep);
    border: none;
    padding: 14px 32px;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    font-weight: 500;
    display: inline-block;
  }

  .btn-primary:hover {
    background: #33CFFF;
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(0,194,255,0.3);
  }

  .btn-secondary {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-bright);
    padding: 14px 32px;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
  }

  .btn-secondary:hover {
    color: var(--text-primary);
    border-color: rgba(200,230,245,0.35);
  }

  /* ── DIVIDER LINE ── */
  .ice-line {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.25;
  }

  /* ── STATS BAR ── */
  .stats-bar {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .stat-item {
    flex: 1;
    max-width: 220px;
    padding: 32px 24px;
    text-align: center;
    border-right: 1px solid var(--border);
  }

  .stat-item:last-child { border-right: none; }

  .stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 44px;
    letter-spacing: 2px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── SECTIONS ── */
  .section {
    position: relative;
    z-index: 1;
    padding: 110px 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
    max-width: 60px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    letter-spacing: 2px;
    line-height: 1;
    margin-bottom: 20px;
  }

  .section-desc {
    font-size: 16px;
    font-weight: 300;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.8;
    margin-bottom: 64px;
  }

  /* ── DASHBOARD PREVIEW ── */
  .dashboard-preview {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.5);
  }

  .dashboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--surface-2);
  }

  .dashboard-title {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .live-dot {
    width: 6px; height: 6px;
    background: var(--alert-green);
    border-radius: 50%;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  .dashboard-date {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
  }

  .games-grid {
    padding: 20px;
    display: grid;
    gap: 10px;
  }

  .game-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 16px 20px;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    align-items: center;
    gap: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .game-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
  }

  .game-card.alert-high::before { background: var(--alert-red); }
  .game-card.alert-mid::before  { background: var(--alert-amber); }
  .game-card.alert-low::before  { background: var(--text-muted); }

  .game-card.alert-high { border-color: rgba(255,68,68,0.18); background: rgba(255,68,68,0.03); }
  .game-card.alert-mid  { border-color: rgba(255,176,32,0.15); background: rgba(255,176,32,0.02); }

  .team-info { display: flex; flex-direction: column; gap: 4px; }
  .team-away { text-align: left; }
  .team-home { text-align: right; }

  .team-abbr {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    letter-spacing: 2px;
    line-height: 1;
  }

  .team-meta {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.3px;
  }

  .team-meta.warn  { color: var(--alert-amber); }
  .team-meta.danger { color: var(--alert-red); }

  .vs-col { text-align: center; }

  .vs-text {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 2px;
  }

  .game-time {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .alert-col { text-align: right; }

  .alert-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 3px;
    margin-bottom: 6px;
  }

  .badge-high { background: rgba(255,68,68,0.12);  color: var(--alert-red);   border: 1px solid rgba(255,68,68,0.25); }
  .badge-mid  { background: rgba(255,176,32,0.10); color: var(--alert-amber); border: 1px solid rgba(255,176,32,0.2); }
  .badge-none { background: rgba(61,90,110,0.15);  color: var(--text-muted);  border: 1px solid var(--border); }

  .edge-score {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
  }

  .edge-score span { color: var(--accent); }

  /* ── FEATURES GRID ── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .feature-card {
    background: var(--surface);
    padding: 44px 36px;
    transition: background 0.2s;
  }

  .feature-card:hover { background: var(--surface-2); }

  .feature-icon {
    font-size: 30px;
    margin-bottom: 22px;
    display: block;
  }

  .feature-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 26px;
    letter-spacing: 1.5px;
    margin-bottom: 12px;
  }

  .feature-desc {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  /* ── HOW IT WORKS ── */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    counter-reset: steps;
  }

  .how-card {
    background: var(--surface);
    padding: 40px 28px;
    position: relative;
    counter-increment: steps;
  }

  .how-card::before {
    content: "0" counter(steps);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 64px;
    letter-spacing: 2px;
    color: var(--border-bright);
    line-height: 1;
    display: block;
    margin-bottom: 20px;
  }

  .how-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .how-desc {
    font-size: 13px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  /* ── PRICING ── */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .pricing-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 44px 36px;
    position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }

  .pricing-card:hover {
    border-color: var(--border-bright);
    transform: translateY(-3px);
  }

  .pricing-card.featured {
    border-color: rgba(0,194,255,0.3);
    background: var(--surface-2);
  }

  .pricing-card.featured::before {
    content: 'MOST POPULAR';
    position: absolute;
    top: -1px; left: 50%;
    transform: translateX(-50%);
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--deep);
    background: var(--accent);
    padding: 4px 14px;
    border-radius: 0 0 4px 4px;
    white-space: nowrap;
  }

  .plan-name {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .plan-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 72px;
    letter-spacing: 2px;
    line-height: 1;
    margin-bottom: 4px;
  }

  .plan-price sup {
    font-size: 28px;
    vertical-align: top;
    margin-top: 14px;
    color: var(--text-secondary);
  }

  .plan-period {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    margin-bottom: 36px;
    line-height: 1.6;
  }

  .plan-period .beta-price {
    color: var(--accent);
    font-size: 11px;
  }

  .plan-features {
    list-style: none;
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .plan-features li {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.5;
  }

  .plan-features li::before {
    content: '—';
    font-family: 'DM Mono', monospace;
    color: var(--accent);
    flex-shrink: 0;
  }

  .plan-features li.dim { color: var(--text-muted); }
  .plan-features li.dim::before { color: var(--text-muted); }

  /* ── BETA SECTION ── */
  .beta-section {
    position: relative;
    z-index: 1;
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 100px 40px;
    text-align: center;
    overflow: hidden;
  }

  .beta-section::before {
    content: 'ICE COLD';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(100px, 20vw, 240px);
    letter-spacing: 20px;
    color: rgba(0,194,255,0.025);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }

  .beta-inner {
    position: relative;
    z-index: 1;
    max-width: 580px;
    margin: 0 auto;
  }

  .beta-tag {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--alert-amber);
    border: 1px solid rgba(255,176,32,0.25);
    padding: 6px 16px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 28px;
  }

  .beta-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(44px, 7vw, 80px);
    letter-spacing: 3px;
    line-height: 1;
    margin-bottom: 20px;
  }

  .beta-desc {
    font-size: 16px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 40px;
  }

  .email-form {
    display: flex;
    gap: 12px;
    max-width: 460px;
    margin: 0 auto 16px;
  }

  .email-input {
    flex: 1;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    background: var(--surface-3);
    border: 1px solid var(--border-bright);
    color: var(--text-primary);
    padding: 14px 20px;
    border-radius: 3px;
    outline: none;
    transition: border-color 0.2s;
  }

  .email-input::placeholder { color: var(--text-muted); }
  .email-input:focus { border-color: rgba(0,194,255,0.45); }

  .form-note {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--text-muted);
  }

  /* ── CA BADGE ── */
  .ca-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 6px 14px;
    border-radius: 2px;
    margin-top: 40px;
  }

  /* ── FOOTER ── */
  footer {
    position: relative;
    z-index: 1;
    padding: 48px 40px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-wordmark { text-decoration: none; }

  .footer-logo-top {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 5px;
    color: var(--text-muted);
  }

  .footer-logo-top span { color: var(--text-secondary); }

  .footer-logo-bottom {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 3px;
    color: var(--text-muted);
    opacity: 0.5;
    text-transform: uppercase;
  }

  .footer-links {
    display: flex;
    gap: 28px;
    list-style: none;
  }

  .footer-links a {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--text-secondary); }

  .footer-right {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    text-align: right;
    line-height: 1.8;
  }

  /* ── DISCLAIMER ── */
  .disclaimer {
    position: relative;
    z-index: 1;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    text-align: center;
    padding: 20px 40px 28px;
    line-height: 1.9;
    border-top: 1px solid var(--border);
    opacity: 0.7;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.75s ease, transform 0.75s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    .hero { padding: 120px 24px 80px; }
    .stats-bar { flex-wrap: wrap; }
    .stat-item { min-width: 50%; border-right: none; border-bottom: 1px solid var(--border); }
    .features-grid { grid-template-columns: 1fr; }
    .how-grid { grid-template-columns: 1fr 1fr; }
    .pricing-grid { grid-template-columns: 1fr; }
    .section { padding: 70px 24px; }
    .email-form { flex-direction: column; }
    .game-card { grid-template-columns: 1fr 1fr; gap: 12px; }
    .vs-col { display: none; }
    .alert-col { grid-column: 1 / -1; text-align: left; }
    footer { flex-direction: column; gap: 28px; text-align: center; }
    .footer-right { text-align: center; }
